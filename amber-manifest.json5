{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      openrouter_api_key: { type: "string", secret: true },
    },
    required: ["openrouter_api_key"],
    additionalProperties: false,
  },

  slots: {
    proxy: { kind: "a2a", optional: true },
  },

  program: {
    image: "ghcr.io/1y2u3i4-boop/agentbeats-mle-bench:latest",
    entrypoint: "uv run python src/server.py --host 0.0.0.0 --port 9010",

    env: {
      OPENROUTER_API_KEY: "${config.openrouter_api_key}",
    },

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9010 },
      ],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },
}

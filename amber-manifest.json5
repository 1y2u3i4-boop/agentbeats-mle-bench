{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      openai_api_key: { type: "string", secret: true },
      openai_model: { type: "string" },
      max_iterations: { type: "string" },
      num_attempts: { type: "string" },
      code_timeout: { type: "string" },
    },
    required: ["openai_api_key"],
    additionalProperties: false,
  },

  slots: {
    proxy: { kind: "a2a", optional: true },
  },

  program: {
    image: "ghcr.io/a-kirillov/agentbeats-mle-bench:latest",
    entrypoint: "uv run python src/server.py --host 0.0.0.0 --port 9010",

    env: {
      OPENAI_API_KEY: "${config.openai_api_key}",
      OPENAI_MODEL: "${config.openai_model || 'o4-mini'}",
      MAX_ITERATIONS: "${config.max_iterations || '12'}",
      NUM_ATTEMPTS: "${config.num_attempts || '3'}",
      CODE_TIMEOUT: "${config.code_timeout || '600'}",
    },

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9010 },
      ],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },
}
